# Public site URL (used by sitemap, RSS, OG, etc.)
NEXT_PUBLIC_SITE_URL=https://dongding.dev

# Umami analytics (cloud.umami.is) — leave website ID blank to disable script.
NEXT_PUBLIC_UMAMI_WEBSITE_ID=
NEXT_PUBLIC_UMAMI_SCRIPT_URL=https://cloud.umami.is/script.js

# Umami share URL (Settings → Websites → Enable share URL) — used by
# client-side stats components (post views, top posts). Leave blank to hide.
NEXT_PUBLIC_UMAMI_SHARE_ID=
NEXT_PUBLIC_UMAMI_SHARE_BASE=https://cloud.umami.is/analytics/us/api

# Umami API key (Profile → API keys) — server-only, used by the dev-only
# /admin/stats panel via /api/stats/* proxy routes. Never exposed to client.
UMAMI_API_KEY=
UMAMI_API_BASE=https://api.umami.is/v1

# Giscus (GitHub Discussions comments) — all four required to activate.
# Get values from https://giscus.app/ after wiring your repo.
NEXT_PUBLIC_GISCUS_REPO=
NEXT_PUBLIC_GISCUS_REPO_ID=
NEXT_PUBLIC_GISCUS_CATEGORY=
NEXT_PUBLIC_GISCUS_CATEGORY_ID=

# Personal access token used by the dev-only admin dashboard to fetch
# the latest Giscus discussion comments via the GitHub GraphQL API.
# Scope: `public_repo` (classic) or `Discussions: Read` (fine-grained).
# Leave blank to render the "no comments" empty state.
GITHUB_TOKEN=
